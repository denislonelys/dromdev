# ============================================================================
# IIStudio — Пример файла конфигурации
# Скопируй в .env и заполни своими данными:
#   cp .env.example .env && nano .env
# ============================================================================

# ── ОСНОВНЫЕ НАСТРОЙКИ ───────────────────────────────────────────────────────
IISTUDIO_ENV=production
IISTUDIO_DEBUG=false
IISTUDIO_LOG_LEVEL=INFO
IISTUDIO_VERSION=1.0.0

# ── API СЕРВЕР ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_MIN_32_CHARS
METRICS_PORT=9090

# ── ARENA.AI АККАУНТ ─────────────────────────────────────────────────────────
ARENA_EMAIL=your@email.com
ARENA_PASSWORD=your_arena_password
ARENA_BASE_URL=https://arena.ai

# ── БАЗА ДАННЫХ (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://iistudio:your_db_pass@localhost:5432/iistudio
POSTGRES_DB=iistudio
POSTGRES_USER=iistudio
POSTGRES_PASSWORD=your_db_pass
POSTGRES_PORT=5432

# ── КЭШ (Redis) ──────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_pass@localhost:6379/0
REDIS_PASSWORD=your_redis_pass
REDIS_PORT=6379
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# ── ПРОКСИ ───────────────────────────────────────────────────────────────────
PROXY_FILE=proxy.txt
PROXY_CHECK_INTERVAL=300
PROXY_MAX_FAILURES=3
# MTProto SOCKS5 туннель (если используешь отдельный контейнер mtg)
MTPROTO_SOCKS5_HOST=127.0.0.1
MTPROTO_SOCKS5_PORT=11080
# Для docker-compose (mtproto-tunnel контейнер):
# MTPROTO_SOCKS5_HOST=mtproto-tunnel
# Первый прокси из proxy.txt для mtg контейнера:
MTG_PROXY_HOST=tg.atomic-vpn.com
MTG_PROXY_PORT=443
MTG_PROXY_SECRET=dd3f087f3f403449a2a9446de22b5bc3d1

# ── БРАУЗЕР (Playwright/Chromium) ────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=60000
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# ── ОРКЕСТРАТОР ──────────────────────────────────────────────────────────────
MAX_PARALLEL_REQUESTS=5
REQUEST_TIMEOUT=120
MAX_RETRIES=3
DEFAULT_MODE=text
DEFAULT_MODEL=claude-3-5-sonnet

# ── ОЧЕРЕДИ (Celery) ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:your_redis_pass@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_pass@localhost:6379/2

# ── УВЕДОМЛЕНИЯ TELEGRAM (опционально) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── EMAIL (опционально) ───────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── CAPTCHA (опционально) ─────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=

# ── МОНИТОРИНГ ────────────────────────────────────────────────────────────────
ENABLE_METRICS=true
ENABLE_TRACING=false

# ── БЕЗОПАСНОСТЬ ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
MAX_REQUEST_SIZE_MB=10
SESSION_TTL_HOURS=24
